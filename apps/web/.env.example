# Copy this file to apps/web/.env.local.
#
# Option A: Vertex API key.
VERTEX_API_KEY=
#
# Option B: service account JSON.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
VERTEX_LOCATION=us-central1
VERTEX_USE_GCE_METADATA=false

VERTEX_MODEL=gemini-2.5-flash

# Optional Qwen combiner VM endpoint.
QWEN_COMBINER_BASE_URL=
QWEN_COMBINER_API_KEY=
QWEN_COMBINER_MODEL=qwen3-4b-dpo-softce

# Local Postgres for dataset and generated recipe persistence.
DATABASE_URL=postgres://llm_craft:llm_craft_dev@localhost:5432/llm_craft

# Admin dashboard at /admin (start/stop the GPU VM). Unset = dashboard disabled.
ADMIN_DASH_USER=
ADMIN_DASH_PASSWORD=

# GPU VM controlled from /admin (defaults shown).
QWEN_VM_NAME=qwen-combiner-test
QWEN_VM_ZONE=us-central1-a
